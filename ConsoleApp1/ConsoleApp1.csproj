<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <Compile Remove="Client\**" />
      <Compile Remove="ConcreteCreators\**" />
      <Compile Remove="Creator\**" />
      <EmbeddedResource Remove="Client\**" />
      <EmbeddedResource Remove="ConcreteCreators\**" />
      <EmbeddedResource Remove="Creator\**" />
      <None Remove="Client\**" />
      <None Remove="ConcreteCreators\**" />
      <None Remove="Creator\**" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="ClosedXML" Version="0.105.0" />
      <PackageReference Include="QuestPDF" Version="2026.2.2" />
    </ItemGroup>

    <ItemGroup>
      <None Update="students.json">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
    </ItemGroup>

</Project>
